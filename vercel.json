{
  "version": 2,
  "builds": [
    {
      "src": "apps/web/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/driver/(.*)",
      "dest": "apps/web/driver/$1"
    },
    {
      "src": "/projects/(.*)",
      "dest": "apps/web/projects/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "apps/web/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "apps/web/$1"
    }
  ]
}
